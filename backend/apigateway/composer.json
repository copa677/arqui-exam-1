{
    "name": "spaceshift/apigateway",
    "description": "API Gateway central para los microservicios",
    "type": "project",
    "require": {
        "php": ">=8.2.12",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [{
        "name": "packagist",
        "type": "composer",
        "url": "http://repo.packagist.org"
    }],
    "config": {
        "secure-http": false,
        "disable-tls": true
    }
}
